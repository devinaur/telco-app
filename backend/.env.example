# Server Configuration
PORT=5000
FLASK_ENV=development
SECRET_KEY=change_this_to_a_random_secret_string

# Frontend Configuration
# Gunakan http://localhost:9000 untuk lokal development
FRONTEND_URL=http://localhost:9000

# Email Service (SendGrid)
# Masukkan API Key dari dashboard SendGrid (Format: SG.xxxx...)
SENDGRID_API_KEY=SG.your_api_key_here
# Email pengirim yang sudah diverifikasi di SendGrid
MAIL_SENDER=your_email@example.com

# Database Configuration (PostgreSQL)
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/telco_app